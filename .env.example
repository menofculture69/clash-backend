PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://username:password@ep-example-ap-south-1.neon.tech/clash_companion?sslmode=require
CLASH_API_BASE_URL=https://api.clashofclans.com/v1
CLASH_API_JWT=replace_with_clash_api_jwt
APP_JWT_SECRET=replace_with_long_random_secret
APP_REFRESH_SECRET=replace_with_different_long_random_secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
PLAYER_CACHE_TTL_SECONDS=120
CLAN_CACHE_TTL_SECONDS=120
GLOBAL_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
ADMIN_API_KEY=replace_with_a_long_random_admin_api_key
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
